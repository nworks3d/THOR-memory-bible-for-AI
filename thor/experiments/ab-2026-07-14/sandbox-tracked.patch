+/// Stall-after-commitment detector (idea adoption: mann1x/claude-hooks
+/// `stop_guard`). Fires when the reply's LAST paragraph makes a first-person
+/// FUTURE-INTENT commitment to act ("I'll run X", "let me update Y", "ik ga Z
+/// doen") yet the turn is ending - a promise never executed. Tail-only, so a
+/// commitment earlier in a long reply that WAS carried out does not trip it; a
+/// trailing question is exempt (handing control back is deliberate), and the
+/// common ask/hand-off forms ("I'll wait", "let me know", "I'll need you") are
+/// excluded. Dep-free substring logic, conservative markers only, since the
+/// Stop guard blocks by default and a false positive costs a forced extra turn.
+fn stall_detect(msg: &str) -> bool {
+    let trimmed = msg.trim_end();
+    let tail = trimmed.rsplit("\n\n").next().unwrap_or(trimmed).trim();
+    if tail.is_empty() || tail.ends_with('?') {
+        return false;
+    }
+    let lower = tail.to_lowercase();
+    const NOT_STALL: &[&str] = &[
+        "i'll wait", "i'll need you", "i'll let you", "i'll be here",
+        "let me know", "ik wacht", "laat me weten", "laat het me weten",
+    ];
+    if NOT_STALL.iter().any(|n| lower.contains(n)) {
+        return false;
+    }
+    const COMMITMENTS: &[&str] = &[
+        "i'll ", "i will ", "let me ", "i'm going to ", "i am going to ",
+        "next i'll ", "now i'll ", "i'm now going to ",
+        "ik ga ", "ik zal ", "laat me ", "ik ga nu ",
+    ];
+    COMMITMENTS.iter().any(|c| lower.contains(c))
+}
+
+const STALL_REASON: &str = "[THOR stall-guard] Your reply commits to an action \
+    (\"I'll ...\" / \"let me ...\") but the turn is ending without doing it. If you \
+    intended to act, take the action now instead of stopping; if you meant to ask \
+    or hand off, phrase it as a question.";
+
+/// Secret-at-capture detector (idea adoption: agentmemory privacy filter, but
+/// dep-free and entropy-backed since a denylist alone trails new token formats).
+/// Returns labels of secret-shaped spans in a to-be-stored body so `remember`
+/// can WARN before a credential enters the lossless log (where it can never be
+/// deleted). Detection only, never rewrites. Tuned so THOR's own ID-heavy text
+/// (ULIDs are UPPER+digit, git hashes are lower+digit) does NOT false-fire: the
+/// entropy backstop requires all three character classes, which real mixed
+/// credentials have but ULIDs/hex hashes/UUIDs do not.
+fn scan_secrets(body: &str) -> Vec<&'static str> {
+    let mut hits: Vec<&'static str> = Vec::new();
+    let lower = body.to_lowercase();
+    const PREFIXES: &[(&str, &str)] = &[
+        ("sk-ant-", "anthropic-key"),
+        ("sk-proj-", "openai-proj-key"),
+        ("ghp_", "github-pat"),
+        ("gho_", "github-oauth"),
+        ("ghs_", "github-server"),
+        ("github_pat_", "github-fine-pat"),
+        ("xoxb-", "slack-bot"),
+        ("xoxp-", "slack-user"),
+        ("glpat-", "gitlab-pat"),
+        ("-----begin", "private-key-block"),
+    ];
+    for (p, label) in PREFIXES {
+        if lower.contains(p) {
+            hits.push(label);
+        }
+    }
+    // AWS/Google keys are case-sensitive prefixes on a specific length.
+    for tok in body.split(|c: char| !(c.is_ascii_alphanumeric() || c == '_' || c == '-')) {
+        if (tok.starts_with("AKIA") || tok.starts_with("ASIA")) && tok.len() >= 20 {
+            hits.push("aws-access-key");
+        }
+        if tok.starts_with("AIza") && tok.len() >= 30 {
+            hits.push("google-api-key");
+        }
+        // Entropy backstop for prefix-less credentials. Requires >= 24 chars AND
+        // all three classes (lower+upper+digit) AND high Shannon entropy, so a
+        // ULID (upper+digit) or a hex hash (lower+digit) never trips it.
+        if tok.len() >= 24 && has_all_classes(tok) && shannon_bits(tok) >= 3.7 {
+            hits.push("high-entropy-token");
+        }
+    }
+    hits.sort_unstable();
+    hits.dedup();
+    hits
+}
+
+fn has_all_classes(s: &str) -> bool {
+    s.chars().any(|c| c.is_ascii_lowercase())
+        && s.chars().any(|c| c.is_ascii_uppercase())
+        && s.chars().any(|c| c.is_ascii_digit())
+}
+
+fn shannon_bits(s: &str) -> f64 {
+    use std::collections::HashMap;
+    let mut counts: HashMap<char, usize> = HashMap::new();
+    for c in s.chars() {
+        *counts.entry(c).or_insert(0) += 1;
+    }
+    let n = s.chars().count() as f64;
+    -counts
+        .values()
+        .map(|&c| {
+            let p = c as f64 / n;
+            p * p.log2()
+        })
+        .sum::<f64>()
+}
